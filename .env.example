# ---------------------------------------------------------------------------
# Contest Agent configuration. Copy to `.env` and edit. All values optional;
# sensible defaults are applied in config.py.
# ---------------------------------------------------------------------------

# --- Source workbooks (point these at the real shared files in prod) --------
LIBRARY_WORKBOOK=./data/Library__All_Programs.xlsx
TRACKER_WORKBOOK=./data/NV_contests_Tracker_Q2-2026_.xlsx
TRACKER_SHEET=Academy New Contests 
TRACKER_FIRST_DATA_ROW=4

# --- Local metadata store (never written into the tracker) ------------------
METADATA_DB=./data/contest_agent.sqlite3

# --- Default program when not specified -------------------------------------
DEFAULT_PROGRAM=academy

# --- Contest naming + duration ----------------------------------------------
CONTEST_NAME_TEMPLATE={module}: NV Contest {month} {year}
DEFAULT_CONTEST_DURATION_MIN=90

# --- Re-attempt window rule (days) ------------------------------------------
REATTEMPT_A2_DAYS=7
REATTEMPT_A3_DAYS=9
REATTEMPT_A4_DAYS=10

# --- ngrok public tunnel (read by start.sh) ---------------------------------
# Static domain from your ngrok dashboard — never changes between restarts.
NGROK_DOMAIN=shale-unfailing-backyard.ngrok-free.dev
STREAMLIT_PORT=8501

# --- Browser / Playwright ---------------------------------------------------
HEADLESS=true
SLOW_MO_MS=0
DEFAULT_TIMEOUT_MS=30000
NAV_TIMEOUT_MS=45000
STORAGE_STATE_PATH=./data/storage_state.json
# USER_DATA_DIR=

# --- Retry policy -----------------------------------------------------------
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0

# --- Target system URLs (override only if they change) ----------------------
URL_ADMIN_BATCHES=https://www.scaler.com/admin/academy/v2/batches
URL_SCHEDULE_CLASSES=https://www.scaler.com/scm/classes/schedule-classes
URL_VIEW_SCHEDULE=https://www.scaler.com/scm/classes/view-schedule
URL_HIRE_TEST_BASE=https://www.scaler.com/hire/test
