# NV Contest Agent — Streamlit secrets example
# ─────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in the values.
# NEVER commit secrets.toml — it is gitignored.

# ── App login ─────────────────────────────────────────────────────────────
# Password for the Streamlit login gate (all authorised users share this).
APP_PASSWORD = "your-strong-password"

# ── Session cookie signing ─────────────────────────────────────────────────
# 32-byte random hex used to sign the 7-day login cookie.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET = "your-64-char-hex-string"

# ── Playwright auth state (headless runs) ─────────────────────────────────
# Base64-encoded contents of data/storage_state.json.
# Generate / refresh: python capture_login.py
# Update this secret whenever the Scaler session expires (~weeks/months).
# On Community Cloud this is the bootstrap source because the filesystem
# is ephemeral; on local/server deployments the file itself is used.
STORAGE_STATE_B64 = ""

# ── Google Sheets tracker ─────────────────────────────────────────────────
# Required for the tracker step on Community Cloud (no local Excel file there).
# The sheet ID is the long string in the Google Sheets URL.
GOOGLE_SHEET_ID = "your-sheet-id-from-the-url"

# Base64-encoded contents of data/service_account.json (the GCP service account
# key file).  On Community Cloud the file won't exist; this secret is the
# bootstrap source.  Generate:
#   base64 -i data/service_account.json | tr -d '\n'
# Or in Python:
#   import base64; print(base64.b64encode(open('data/service_account.json','rb').read()).decode())
SERVICE_ACCOUNT_B64 = ""

# Tab names (override only if yours differ from the defaults below).
# GOOGLE_SHEET_NAME_ACADEMY = "Academy New Contests "   # note trailing space
# GOOGLE_SHEET_NAME_DEVOPS  = "DevOps Contests"
# GOOGLE_SHEET_NAME_DSML    = "DSML Contests"
# GOOGLE_SHEET_NAME_AIML    = "AIML Contests"
