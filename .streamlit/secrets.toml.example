# NV Contest Agent — Streamlit secrets example
# ─────────────────────────────────────────────
# Copy to .streamlit/secrets.toml and fill in the values.
# NEVER commit secrets.toml — it is gitignored.
#
# LOCAL (Mac + ngrok) — only two keys are required:
#   APP_PASSWORD    shared password for the login gate
#   SESSION_SECRET  32-byte hex for signing the 7-day login cookie
#
# CLOUD (Streamlit Community Cloud — currently dormant) — additional keys
#   needed because the cloud filesystem is ephemeral:
#   STORAGE_STATE_B64, GOOGLE_CREDS_B64, GOOGLE_SHEET_ID

# ── App login ─────────────────────────────────────────────────────────────
# Password shared with all ~15 internal users via Slack/email.
APP_PASSWORD = "your-strong-password"

# ── Session cookie signing ─────────────────────────────────────────────────
# Signs the 7-day login cookie so refreshing the ngrok URL keeps you logged in.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET = "your-64-char-hex-string"

# ── Google Sheets tracker (optional) ─────────────────────────────────────
# Set GOOGLE_SHEET_ID if you want the Google Sheet tracker.
# service_account.json is read from data/ locally — no base64 needed.
# GOOGLE_SHEET_ID = "your-sheet-id-from-the-url"

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CLOUD-ONLY keys (not needed for local Mac + ngrok setup)               ║
# ║  Keep these commented out locally — their absence is silent / harmless. ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Base64-encoded Scaler session state (ephemeral cloud filesystem only).
# Locally: data/storage_state.json is used directly.
# Generate: python3 capture_login.py  (prints the STORAGE_STATE_B64 line)
# STORAGE_STATE_B64 = ""

# Base64-encoded Google service-account key (cloud filesystem only).
# Locally: data/service_account.json is used directly.
# Generate: base64 -i data/service_account.json | tr -d '\n'
# GOOGLE_CREDS_B64 = ""
# SERVICE_ACCOUNT_B64 = ""   # legacy alias — GOOGLE_CREDS_B64 is preferred

# Per-program Google Sheet tab names (only if yours differ from defaults).
# GOOGLE_SHEET_NAME_ACADEMY = "Academy New Contests "   # note trailing space
# GOOGLE_SHEET_NAME_DEVOPS  = "DevOps Contests"
# GOOGLE_SHEET_NAME_DSML    = "DSML Contests"
# GOOGLE_SHEET_NAME_AIML    = "AIML Contests"
